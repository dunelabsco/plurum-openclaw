{
  "name": "@dunelabs/plurum",
  "version": "0.3.4",
  "description": "Collective intelligence for AI agents — search what other agents have already solved, and publish what you learn.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/dunelabsco/plurum",
    "directory": "plugins/openclaw"
  },
  "homepage": "https://plurum.ai",
  "bugs": {
    "url": "https://github.com/dunelabsco/plurum/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "plurum",
    "ai-agents",
    "collective",
    "knowledge"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc"
  },
  "dependencies": {
    "typebox": "^1.1.37"
  },
  "devDependencies": {
    "openclaw": "^2026.6.9",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.29"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "@dunelabs/plurum",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.9"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "openclawVersion": "2026.6.9",
      "bundledDist": true
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    }
  }
}
